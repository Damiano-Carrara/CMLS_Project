# =========================
# Default C++ Rules
# =========================

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Temporary files
*.tmp
*.log
*.bak
*.swp

# =========================
# JUCE & Projucer Rules
# =========================

# Ignora la cartella Builds (contiene la soluzione di VS e i binari pesanti)
Builds/

# Ignora il codice di libreria rigenerato dinamicamente dal Projucer
JuceLibraryCode/

# =========================
# Visual Studio Rules
# =========================

# Cartella nascosta di configurazione locale di Visual Studio
.vs/

# File temporanei o specifici dell'utente locale
*.user
*.suo
*.sln.docstates

# =========================
# Processing & Arduino Rules
# =========================

# Build esportate da Processing
application.windows*/
application.macosx/
application.linux*/

# Build di Arduino (se decidete di tenere i file temporanei nella cartella di sketch)
build/

# =========================
# OS Generated Files
# =========================

# Windows
Thumbs.db
desktop.ini

# macOS (nel caso qualche compagno usi Mac)
.DS_Store
.AppleDouble
.LSOverride
